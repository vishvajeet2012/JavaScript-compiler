# Copy to .env for local (never commit .env)
NODE_ENV=development
PORT=5000

# Comma-separated allowed origins
CORS_ORIGIN=http://localhost:3000,http://localhost:5173,https://jsplay-kappa.vercel.app,https://vishvajeetshukla.in

# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://USER:PASS@cluster.mongodb.net/js-compiler?retryWrites=true&w=majority

# Admin panel password (Bearer token = same value)
ADMIN_SECRET=change-me-strong-password

# HMAC secret for activation tokens
ACTIVATION_SECRET=change-me-long-random-string

RATE_LIMIT_MAX=200
RATE_LIMIT_WINDOW_MS=900000

# Cloudflare R2 (admin release uploads + signed downloads)
# Browser uploads go direct to R2 via presigned PUT (large .exe OK)
R2_ACCOUNT_ID=
R2_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
R2_BUCKET_NAME=javascript
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
# Optional public CDN base (if bucket has public access / custom domain)
R2_PUBLIC_BASE_URL=
R2_SIGNED_URL_TTL=3600
