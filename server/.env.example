# Server Environment Variables
# Local: copy to .env
# Vercel: set the same keys in Project → Settings → Environment Variables

NODE_ENV=production
PORT=5000

# Frontend origins (comma-separated, no trailing slash)
CORS_ORIGIN=https://jsplay-kappa.vercel.app,http://localhost:3000,http://localhost:5173

# MongoDB Atlas
MONGODB_URI=mongodb+srv://USER:PASS@cluster0.kqih8fi.mongodb.net/js-compiler?appName=Cluster0

# Admin panel password / API token
ADMIN_SECRET=change-me-strong-password

# HMAC secret for Electron activation tokens
ACTIVATION_SECRET=change-me-activation-secret

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200
