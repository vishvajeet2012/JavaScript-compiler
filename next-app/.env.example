# Next.js Environment Variables
# Local: copy to .env.local
# Vercel: Project → Settings → Environment Variables

# Express API base URL (no trailing slash)
# Local:
# NEXT_PUBLIC_API_URL=http://localhost:5000
# Production (Vercel Express API):
NEXT_PUBLIC_API_URL=https://java-script-server.vercel.app

# Cloudflare R2 (S3-compatible) — NEVER commit real secrets
R2_ACCOUNT_ID=
R2_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
R2_BUCKET_NAME=javascript
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_API_TOKEN=
R2_OBJECT_KEY=releases/JS-Compiler-Setup-1.0.0.exe
R2_DOWNLOAD_FILENAME=JS Compiler-Setup-1.0.0.exe

# Download rate limit (IP-based) — requires R2 for counters
DOWNLOAD_LIMIT_PER_IP=5
DOWNLOAD_WINDOW_HOURS=24

# If R2 is missing on the host, API falls back to this public installer URL
DOWNLOAD_GITHUB_FALLBACK_URL=https://github.com/vishvajeet2012/JavaScript-compiler/releases/latest/download/JS-Compiler-Setup-1.0.0.exe

# Admin download stats — must match admin login password (ADMIN_SECRET on server)
DOWNLOAD_STATS_SECRET=
ADMIN_SECRET=

# ── Vercel: add ALL R2_* + DOWNLOAD_* under Project → Settings → Environment Variables
# Then redeploy. Without R2 keys, production uses GitHub fallback only.
