{
  "name": "javascript-compiler",
  "version": "1.0.0",
  "description": "Desktop JavaScript Compiler with local DB and Pro activation",
  "main": "electron/main.js",
  "author": "vishvajeet shukla <vishvajeet2012>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/vishvajeet2012/JavaScript-compiler.git"
  },
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "server": "node activation-server/server.js",
    "build": "electron-builder --win --linux --mac",
    "build:win": "electron-builder --win --x64",
    "build:win:signed": "electron-builder --win --config.win.signAndEditExecutable=true",
    "build:linux": "electron-builder --linux",
    "build:mac": "electron-builder --mac",
    "publish": "electron-builder --win --linux --mac --publish always",
    "publish:win": "electron-builder --win --publish always",
    "release": "electron-builder --win --linux --mac --publish always"
  },
  "dependencies": {
    "better-sqlite3": "^11.8.1",
    "electron-updater": "^6.6.2",
    "node-machine-id": "^1.1.12"
  },
  "devDependencies": {
    "electron": "^35.0.1",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.vishvajeet.javascript-compiler",
    "productName": "JS Compiler",
    "copyright": "Copyright © 2026 vishvajeet shukla",
    "directories": {
      "output": "dist",
      "buildResources": "assets"
    },
    "files": [
      "electron/**/*",
      "src/**/*",
      "assets/icon.png",
      "package.json"
    ],
    "asar": true,
    "generateUpdatesFilesForAllChannels": true,
    "publish": [
      {
        "provider": "github",
        "owner": "vishvajeet2012",
        "repo": "JavaScript-compiler",
        "releaseType": "release"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "icon": "assets/icon.png",
      "artifactName": "${productName}-Setup-${version}.${ext}",
      "publisherName": ["vishvajeet shukla"],
      "signingHashAlgorithms": ["sha256"],
      "rfc3161TimeStampServer": "http://timestamp.digicert.com",
      "timeStampServer": "http://timestamp.digicert.com",
      "signAndEditExecutable": false,
      "verifyUpdateCodeSignature": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "JS Compiler",
      "uninstallDisplayName": "JS Compiler",
      "deleteAppDataOnUninstall": false,
      "differentialPackage": true
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": ["x64", "arm64"]
        },
        {
          "target": "zip",
          "arch": ["x64", "arm64"]
        }
      ],
      "category": "public.app-category.developer-tools",
      "icon": "assets/icon.png",
      "artifactName": "${productName}-${version}-${arch}.${ext}",
      "hardenedRuntime": false,
      "gatekeeperAssess": false
    },
    "dmg": {
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Development",
      "icon": "assets/icons",
      "synopsis": "Desktop JavaScript Compiler",
      "description": "Write, run and save JavaScript snippets with folders, templates, and Pro activation.",
      "desktop": {
        "Name": "JS Compiler",
        "Comment": "Desktop JavaScript Compiler",
        "Categories": "Development;IDE;TextEditor;",
        "StartupWMClass": "js-compiler"
      },
      "artifactName": "${productName}-${version}.${ext}"
    },
    "deb": {
      "packageName": "js-compiler",
      "depends": [
        "libnotify4",
        "libxtst6",
        "libnss3",
        "libsecret-1-0",
        "libgtk-3-0"
      ]
    }
  }
}

